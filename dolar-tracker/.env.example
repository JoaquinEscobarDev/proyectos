# Obtén tu API Key gratis en https://www.exchangerate-api.com
EXCHANGE_API_KEY=tu_api_key_aqui

# URL del frontend (para CORS)
FRONTEND_URL=https://proyectos.fun

# Token secreto para proteger POST /api/actualizar
UPDATE_TOKEN=cambia_esto_por_un_token_seguro

# Notificaciones push (VAPID) — genera con: node -e "require('web-push').generateVAPIDKeys()"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@tudominio.cl

# Umbral de cambio en CLP para disparar notificación push (default: 3)
UMBRAL_CAMBIO=3

PORT=3000
